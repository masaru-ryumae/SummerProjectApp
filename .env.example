###############################################################################
# ENVIRONMENT CONFIGURATION TEMPLATE
#
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to GitHub (it's in .gitignore)
# NEVER hardcode secrets in source code
#
# Security: All API keys and secrets must be environment variables
###############################################################################

# ────────────────────────────────────────────────────────────────────────────
# FEATURE TOGGLES - Set to 'true' to enable, 'false' to disable
# ────────────────────────────────────────────────────────────────────────────

# V2.1 Features
VITE_FEATURE_FAVORITES=true
VITE_FEATURE_SHARING=true
VITE_FEATURE_PROGRESS_TRACKING=true
VITE_FEATURE_RATINGS=true
VITE_FEATURE_AUTH_CLOUD=false
VITE_FEATURE_DISCOVERY=false
VITE_FEATURE_SOCIAL=false
VITE_FEATURE_UX_TOOLS=false

# V3.0 Features
VITE_FEATURE_AI_PERSONALIZATION=false
VITE_FEATURE_GAMIFICATION=false
VITE_FEATURE_API_INTEGRATIONS=false
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_MOBILE_APP=false
VITE_FEATURE_TEAM_FEATURES=false
VITE_FEATURE_MARKETPLACE=false
VITE_FEATURE_MONETIZATION=false
VITE_FEATURE_ENTERPRISE=false
VITE_FEATURE_AI_ASSISTANT=false
VITE_FEATURE_WEBHOOKS_API=false
VITE_FEATURE_CONTENT_STUDIO=false

# ────────────────────────────────────────────────────────────────────────────
# DATABASE & BACKEND
# ────────────────────────────────────────────────────────────────────────────

# Supabase Configuration
# SECURITY: Store actual credentials in .env (not committed to GitHub)
# Set to 'false' to use mock Supabase (default), 'true' to use real backend
VITE_SUPABASE_MOCK=true
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SERVICE_KEY=your-service-key-here

# ────────────────────────────────────────────────────────────────────────────
# PAYMENT PROCESSING (Stripe)
# ────────────────────────────────────────────────────────────────────────────

# SECURITY: Only PUBLISHABLE keys go in frontend (VITE_ prefix)
# SECRET keys (sk_...) MUST ONLY be in backend server, never in frontend
# Get keys from Stripe Dashboard (https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_public_key_here

# ⚠️  BACKEND ONLY - Never use VITE_ prefix for these:
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & OAUTH
# ────────────────────────────────────────────────────────────────────────────

# SECURITY: Only CLIENT IDs go in frontend (VITE_ prefix)
# CLIENT SECRETS must ONLY be on backend server, never in frontend
# All auth should be backend-driven via server endpoints

# Google OAuth (frontend - VITE_)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth (frontend - VITE_)
VITE_GITHUB_CLIENT_ID=your-github-client-id

# LinkedIn OAuth (frontend - VITE_)
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id

# Auth0 (frontend - VITE_)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# ⚠️  BACKEND ONLY - Never use VITE_ prefix for secrets:
# GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# GITHUB_CLIENT_SECRET=your-github-client-secret-here
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret-here
# AUTH0_CLIENT_SECRET=your-auth0-client-secret-here

# ────────────────────────────────────────────────────────────────────────────
# EXTERNAL APIs - BACKEND ONLY
# ────────────────────────────────────────────────────────────────────────────

# ⚠️  BACKEND ONLY - Never expose these in frontend:
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
# SLACK_SIGNING_SECRET=your-slack-signing-secret-here
# DISCORD_BOT_TOKEN=your-discord-bot-token-here
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
# TWILIO_ACCOUNT_SID=AC_your-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# TWILIO_PHONE_NUMBER=+1234567890

# ────────────────────────────────────────────────────────────────────────────
# ANALYTICS & MONITORING
# ────────────────────────────────────────────────────────────────────────────

# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=development

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=G-your-analytics-id

# LogRocket Session Replay
VITE_LOGROCKET_ID=your-logrocket-app-id

# ────────────────────────────────────────────────────────────────────────────
# SESSION & SECURITY TOKENS - BACKEND ONLY
# ────────────────────────────────────────────────────────────────────────────

# ⚠️  BACKEND ONLY - Never expose these in frontend:
# JWT_SECRET=your-strong-random-jwt-secret-string-here-min-32-chars
# CSRF_TOKEN_SALT=your-csrf-salt-here
# SESSION_ENCRYPTION_KEY=your-session-encryption-key-here

# ────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ────────────────────────────────────────────────────────────────────────────

# App Environment (development, staging, production)
VITE_APP_ENV=development

# API Base URL
VITE_API_BASE_URL=http://localhost:5173
VITE_API_TIMEOUT_MS=30000

# File Upload Limits
VITE_MAX_FILE_SIZE_MB=10
VITE_MAX_UPLOAD_FILES=5

# Rate Limiting
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=60000

# ────────────────────────────────────────────────────────────────────────────
# DEBUG & DEVELOPMENT
# ────────────────────────────────────────────────────────────────────────────

# Enable debug logging (never in production)
VITE_DEBUG_MODE=false
VITE_DEBUG_AUTH=false
VITE_DEBUG_API=false

# Source maps (disable in production)
VITE_ENABLE_SOURCE_MAPS=true

###############################################################################
# SETUP INSTRUCTIONS
###############################################################################
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your actual credentials:
#    - Get Stripe keys from https://dashboard.stripe.com/apikeys
#    - Get OAuth credentials from provider dashboards
#    - Generate strong random secrets for JWT_SECRET
#
# 3. NEVER commit .env to GitHub (it's in .gitignore)
#
# 4. For production, use your deployment platform's secrets manager:
#    - Vercel: Environment Variables in project settings
#    - AWS: Secrets Manager
#    - Heroku: Config Vars
#    - Docker: .env files in secrets volume
#
# 5. Verify no secrets are in source code:
#    grep -r "sk_test" src/  # Should return no results
#    grep -r "pk_test" src/  # Should return no results
#
###############################################################################
